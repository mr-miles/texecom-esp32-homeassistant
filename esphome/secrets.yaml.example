# Copy to `esphome/secrets.yaml` and fill in. The real file is
# .gitignored; never commit credentials.
#
# Keys live here for: WiFi (wifi_*), ESPHome native API (api_encryption_key),
# OTA flashing (ota_password), and — added in Phase 1.5 — the MQTT broker
# (mqtt_broker_*) used for Home Assistant auto-discovery.
#
# Generate `api_encryption_key` with:
#     openssl rand -base64 32
# or via the ESPHome dashboard (Settings -> Secrets).

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

ota_password: "pick-a-long-random-string"

# 32 bytes, base64 encoded (ends with =).
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTES=="

# MQTT broker (Phase 1.5+). Point at the existing Mosquitto instance.
# Anonymous-allowed brokers can leave username/password as empty strings.
mqtt_broker_host: "192.168.1.10"
mqtt_broker_username: "esphome"
mqtt_broker_password: "REPLACE_WITH_BROKER_PASSWORD"
